---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Parser from 'rss-parser';

// 1. Fetch Local Markdown Articles
const localArticles = await getCollection('articles');

// 2. Fetch Medium Articles via RSS (using a placeholder or standard medium feed)
// We will try to fetch the RSS feed. If it fails, fallback gracefully.
const MEDIUM_RSS_URL = 'https://medium.com/feed/@sagardashl'; // Fallback to a common username format based on LinkedIn
const parser = new Parser();
let mediumArticles = [];

try {
  const feed = await parser.parseURL(MEDIUM_RSS_URL);
  mediumArticles = feed.items.map(item => {
    // Basic reading time estimation from content length
    const wordCount = item['content:encoded']?.split(/\s+/).length || 0;
    const readingTime = Math.ceil(wordCount / 200) || 1; // 200 wpm
    
    return {
      title: item.title,
      link: item.link,
      date: new Date(item.pubDate!),
      readingTime: `${readingTime} min read`,
      source: 'Medium'
    };
  });
} catch (error) {
  console.warn("Could not fetch medium articles during build.");
}

// 3. Combine and Sort
const allArticles = [
  ...localArticles.map(a => ({
    title: a.data.title,
    link: `/articles/${a.slug}`,
    date: a.data.date,
    readingTime: 'Local', // Local articles can just have a tag or we can calculate similarly 
    source: 'Local'
  })),
  ...mediumArticles
].sort((a, b) => b.date.valueOf() - a.date.valueOf());

---

<BaseLayout title="Articles | Sagar Dash">
  <section class="section animate-in">
    <h1 class="page-title">Articles</h1>
    <p class="page-subtitle">Thoughts, opinions, and technical tutorials.</p>
    
    <div class="articles-list">
      {allArticles.length > 0 ? allArticles.map(article => (
        <a href={article.link} target={article.source === 'Medium' ? "_blank" : "_self"} class="article-card">
          <div class="article-meta">
            <time datetime={article.date.toISOString()}>
              {article.date.toLocaleDateString('en-US', {
                year: 'numeric', month: 'long', day: 'numeric'
              })}
            </time>
            <span class="dot">&bull;</span>
            <span class="read-time">{article.readingTime}</span>
            <span class="dot">&bull;</span>
            <span class="source-tag">{article.source}</span>
          </div>
          <h2 class="article-title">{article.title}</h2>
        </a>
      )) : (
        <p>No articles found yet.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-title {
    font-size: 3rem;
    font-weight: 800;
  }
  .page-subtitle {
    font-size: 1.25rem;
    opacity: 0.8;
    margin-bottom: 3rem;
  }
  .articles-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .article-card {
    display: block;
    padding: 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .article-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
    border-color: var(--brand-color);
  }
  .article-meta {
    font-size: 0.9rem;
    opacity: 0.8;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .article-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0;
  }
  .dot {
    opacity: 0.5;
  }
  .source-tag {
    font-weight: 600;
    color: var(--brand-color);
  }
</style>
