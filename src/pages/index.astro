---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Content as AboutContent } from '../content/about.md';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Sagar Dash | Senior Software Engineer">
  <!-- Hero Section -->
  <section class="section hero animate-in">
    <div class="hero-content">
      <h1 class="hero-title">
        Hi, I'm <span class="highlight">Sagar Dash</span><br/>
        Senior Software Engineer
      </h1>
      <p class="hero-tagline">
        Backend-focused engineer with 8+ years of experience scaling distributed systems.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Get in Touch</a>
        <a href="/articles" class="btn btn-outline">View Articles</a>
      </div>
    </div>
    <div class="hero-avatar">
      <div class="avatar-placeholder"></div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="section">
    <h2 class="section-title">About Me</h2>
    <div class="about-content">
      <AboutContent />
    </div>
  </section>

  <!-- Experience Section -->
  <section id="experience" class="section">
    <h2 class="section-title">Experience</h2>
    <div class="experience-list">
      
      <div class="experience-item">
        <div class="experience-header">
          <div>
            <h3 class="experience-role">Senior Software Engineer</h3>
            <p class="experience-company">Pathao</p>
          </div>
          <span class="experience-period">Sept 2023 - Present</span>
        </div>
        <p class="experience-desc">Backend Engineer leading Go-based distributed services powering logistics and merchant systems in a high-traffic super app.</p>
        <ul class="experience-highlights">
          <li>Design and maintain system architecture</li>
          <li>Lead incident response and root cause analysis</li>
          <li>Optimize high-load endpoints using goroutines (40% latency improvement)</li>
          <li>Mentor junior engineers on distributed systems</li>
        </ul>
      </div>

      <div class="experience-item">
        <div class="experience-header">
          <div>
            <h3 class="experience-role">Lead Specialist, Engineering</h3>
            <p class="experience-company">10 Minute School</p>
          </div>
          <span class="experience-period">Sept 2017 - Sept 2023</span>
        </div>
        <p class="experience-desc">Full-stack developer at Bangladesh's fastest-growing EdTech startup. Collaborated with Product and Mobile teams on complex system architectures.</p>
        <ul class="experience-highlights">
          <li>Architected Live Class backend for 1,000+ concurrent users</li>
          <li>Designed robust payment system with RabbitMQ</li>
          <li>Built high-concurrency quiz engine for massive traffic spikes</li>
          <li>Developed CRM dashboard for operational efficiency</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="section">
    <h2 class="section-title">Skills</h2>
    <div class="skills-grid">
      
      <div class="skill-category">
        <h3 class="category-title">Backend Frameworks</h3>
        <div class="skill-tags">
          <span class="tag">Go</span>
          <span class="tag">Nest.js</span>
          <span class="tag">Gin</span>
          <span class="tag">Go Chi</span>
          <span class="tag">Laravel</span>
        </div>
      </div>

      <div class="skill-category">
        <h3 class="category-title">Cloud & DevOps</h3>
        <div class="skill-tags">
          <span class="tag">Docker</span>
          <span class="tag">Kubernetes</span>
          <span class="tag">Terraform</span>
          <span class="tag">AWS</span>
          <span class="tag">GCP</span>
          <span class="tag">Github Actions</span>
        </div>
      </div>

      <div class="skill-category">
        <h3 class="category-title">Message Queues & Search</h3>
        <div class="skill-tags">
          <span class="tag">RabbitMQ</span>
          <span class="tag">AWS SQS</span>
          <span class="tag">Elasticsearch</span>
        </div>
      </div>

      <div class="skill-category">
        <h3 class="category-title">Databases & Caching</h3>
        <div class="skill-tags">
          <span class="tag">Redis</span>
          <span class="tag">PostgreSQL</span>
          <span class="tag">MySQL</span>
          <span class="tag">MongoDB</span>
        </div>
      </div>

      <div class="skill-category">
        <h3 class="category-title">Other Languages</h3>
        <div class="skill-tags">
          <span class="tag">PHP</span>
          <span class="tag">JavaScript</span>
          <span class="tag">Python</span>
          <span class="tag">TypeScript</span>
        </div>
      </div>

    </div>
  </section>

  <!-- Open Source Section -->
  <section id="open-source" class="section">
    <h2 class="section-title">Open Source</h2>
    <div class="os-grid">
      
      <a href="https://github.com/pathao-eng/courier-woocommerce-plugin/activity?actor=sagar290" target="_blank" rel="noopener noreferrer" class="os-card">
        <div class="os-header">
          <h3 class="os-title">Pathao Courier Woocommerce Plugin</h3>
          <span class="os-role author">Author</span>
        </div>
        <p class="os-desc">Integration plugin for Woocommerce</p>
      </a>

      <a href="https://github.com/sagar290/migo" target="_blank" rel="noopener noreferrer" class="os-card">
        <div class="os-header">
          <h3 class="os-title">Migo</h3>
          <span class="os-role author">Author</span>
        </div>
        <p class="os-desc">Open source project</p>
      </a>

      <a href="https://github.com/hoppscotch/hoppscotch/pull/2556" target="_blank" rel="noopener noreferrer" class="os-card">
        <div class="os-header">
          <h3 class="os-title">Hoppscotch</h3>
          <span class="os-role contributor">Contributor</span>
        </div>
        <p class="os-desc">API development platform</p>
      </a>

      <a href="https://github.com/Shipu/watchable/pull/4" target="_blank" rel="noopener noreferrer" class="os-card">
        <div class="os-header">
          <h3 class="os-title">Watchable</h3>
          <span class="os-role contributor">Contributor</span>
        </div>
        <p class="os-desc">Open source project</p>
      </a>

    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="section">
    <h2 class="section-title">Featured Projects</h2>
    <div class="projects-grid">
      {sortedProjects.length > 0 ? sortedProjects.map(project => (
        <a href={`/projects/${project.slug}`} class="project-card">
          {project.data.coverImage && (
            <img src={project.data.coverImage} alt={project.data.title} class="project-image" />
          )}
          <div class="project-info">
            <h3 class="project-title">{project.data.title}</h3>
            <p class="project-desc">{project.data.description}</p>
            <div class="project-tags">
              {project.data.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      )) : (
        <p>No projects found. Check back soon!</p>
      )}
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="section contact">
    <h2 class="section-title">Get in Touch</h2>
    <p>Feel free to reach out if you want to collaborate, ask a question, or simply say hello!</p>
    
    <!-- Formspree Form -->
    <form class="contact-form" action="https://formspree.io/f/YOUR_FORMSPREE_ID" method="POST">
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required placeholder="Your Name" />
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="your.email@example.com" />
      </div>
      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="5" required placeholder="What's on your mind?"></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Send Message</button>
    </form>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    display: flex;
    align-items: center;
    gap: 3rem;
    min-height: 80vh;
  }
  .hero-content {
    flex: 1;
  }
  .hero-title {
    font-size: 3rem;
    font-weight: 700;
  }
  .highlight {
    color: var(--brand-color);
  }
  .hero-tagline {
    font-size: 1.25rem;
    opacity: 0.8;
    margin-bottom: 2rem;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
  }
  .hero-avatar {
    flex-shrink: 0;
  }
  .avatar-placeholder {
    width: 250px;
    height: 250px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--border-color), var(--card-bg));
    border: 4px solid var(--border-color);
  }

  /* Section Titles */
  .section-title {
    font-size: 2rem;
    margin-bottom: 2rem;
    position: relative;
    display: inline-block;
  }
  .section-title::after {
    content: '';
    position: absolute;
    bottom: -0.5rem;
    left: 0;
    width: 60%;
    height: 4px;
    background: var(--brand-color);
    border-radius: 2px;
  }

  /* About */
  .about-content {
    font-size: 1.1rem;
    line-height: 1.8;
  }
  :global(.about-content ul) {
    margin-top: 1rem;
    padding-left: 1.5rem;
  }
  :global(.about-content li) {
    margin-bottom: 0.5rem;
  }

  /* Experience Timeline */
  .experience-list {
    position: relative;
    padding-left: 2rem;
  }
  .experience-list::before {
    content: '';
    position: absolute;
    top: 0;
    left: 8px; /* Centers the 2px line based on the dot size */
    bottom: 0;
    width: 2px;
    background: var(--border-color);
  }
  
  .experience-item {
    position: relative;
    padding-bottom: 3rem;
  }
  .experience-item:last-child {
    padding-bottom: 0;
  }
  .experience-item::before {
    content: '';
    position: absolute;
    left: -2rem; /* Exact offset needed relative to padding-left */
    top: 0.25rem;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg-color);
    border: 3px solid var(--brand-color);
    z-index: 10;
    box-shadow: 0 0 0 4px var(--bg-color); /* Cut out background effectively */
  }
  
  .experience-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .experience-role {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
  }
  .experience-company {
    font-size: 1rem;
    color: var(--text-color);
    opacity: 0.9;
    font-weight: 500;
  }
  .experience-period {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--brand-color);
    opacity: 0.9;
  }
  .experience-desc {
    margin: 1rem 0;
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.8;
  }
  .experience-highlights {
    padding-left: 1.25rem;
    font-size: 0.95rem;
    opacity: 0.8;
    list-style-type: none; /* Custom bullets */
  }
  .experience-highlights li {
    margin-bottom: 0.5rem;
    position: relative;
  }
  .experience-highlights li::before {
    content: '→';
    position: absolute;
    left: -1.25rem;
    color: var(--brand-color);
    opacity: 0.7;
  }

  /* Skills Grid */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .skill-category {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 2rem;
    height: 100%;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .skill-category:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
    border-color: var(--brand-color);
  }
  .category-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--text-color);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .category-title::before {
    content: '';
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--brand-color);
  }
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: auto;
  }
  .skill-tags .tag {
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    padding: 0.4rem 0.8rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .skill-tags .tag:hover {
    background: var(--text-color);
    color: var(--bg-color);
    border-color: var(--text-color);
  }

  /* Open Source Grid */
  .os-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .os-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
    color: inherit;
  }
  .os-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: var(--brand-color);
  }
  .os-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.75rem;
    gap: 1rem;
  }
  .os-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.4;
  }
  .os-role {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: 9999px;
    white-space: nowrap;
  }
  .os-role.author {
    background-color: rgba(0, 112, 243, 0.1);
    color: var(--brand-color);
    border: 1px solid rgba(0, 112, 243, 0.2);
  }
  .os-role.contributor {
    background-color: var(--bg-color);
    color: var(--text-color);
    border: 1px solid var(--border-color);
    opacity: 0.8;
  }
  .os-desc {
    font-size: 0.95rem;
    opacity: 0.8;
    margin: 0;
    flex-grow: 1;
  }

  /* Projects Grid */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }
  .project-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    display: flex;
    flex-direction: column;
  }
  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow);
    border-color: var(--brand-color);
  }
  .project-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  .project-info {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .project-title {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }
  .project-desc {
    opacity: 0.8;
    font-size: 0.95rem;
    flex: 1;
    margin-bottom: 1rem;
  }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag {
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  /* Contact Form */
  .contact-form {
    background: var(--card-bg);
    padding: 2rem;
    border-radius: 12px;
    border: 1px solid var(--border-color);
    margin-top: 2rem;
  }
  .form-group {
    margin-bottom: 1.5rem;
  }
  .form-group label {
    display: block;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  @media (max-width: 768px) {
    .hero {
      flex-direction: column-reverse;
      text-align: center;
      padding-top: 2rem;
    }
    .hero-actions {
      justify-content: center;
    }
    .avatar-placeholder {
      width: 200px;
      height: 200px;
    }
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
